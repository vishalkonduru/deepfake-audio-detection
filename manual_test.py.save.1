import os
import numpy as np
import joblib
import config

from extract_features import extract_mfcc, extract_spectral

REAL_DIR = "manual_test/real"
FAKE_DIR = "manual_test/fake"

def extract_full_features(file_path: str) -> np.ndarray:
    """Use the same feature combo as training: MFCC + spectral stats."""
    mfcc_feat = extract_mfcc(file_path, n_mfcc=config.N_MFCC)
    spec_feat = extract_spectral(file_path)
    return np.concatenate([mfcc_feat, spec_feat])

